# ─── SENTINEL DASHBOARD — API Keys ───────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# The app works without keys using rich demo data.

# GNews API — https://gnews.io (100 req/day free)
GNEWS_API_KEY=

# TomTom Traffic API — https://developer.tomtom.com (2500 req/day free)
TOMTOM_API_KEY=

# OpenWeatherMap — https://openweathermap.org (1000 req/day free, used for AQI)
OPENWEATHER_API_KEY=

# Server config
PORT=3000
POLL_INTERVAL_MS=300000
